{
  "checkpoint_path": "/data/gpfs/projects/COMP90055/aticinovic/outputs/stage3_checkpoints/llm_stage3_best_portable.pth",
  "data": {
    "source": "coco",
    "annotations_file": "/data/gpfs/projects/COMP90055/aticinovic/datasets/coco/annotations/captions_train2017.json",
    "image_dir": "/data/gpfs/projects/COMP90055/aticinovic/datasets/coco/train2017",
    "concepts": [
      "person",   
      "cat",        
      "car",        
      "airplane",   
      "pizza",       
      "apple",       
      "chair",     
      "laptop",      
      "tree",       
      "traffic light" 
    ],
    "samples_per_concept": 50,
    "seed": 42
  },
  "analysis": {
    "target_layers": [0, 1, 29, 30],
