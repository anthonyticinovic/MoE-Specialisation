    "reduction_method": "tsne",
    "expert_confidence_threshold": 0.6,
    "reduction_params": {
      "n_neighbors": 15,
      "perplexity": 30
    }
  },
  "output": {
    "save_dir": "results/clustering_analysis",
    "save_representations": true
  }
}
